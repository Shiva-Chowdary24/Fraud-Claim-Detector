import React, { useState } from "react";
import { useLocation, useNavigate } from "react-router-dom";
import API from "../services/api";
import { ShieldCheck, ArrowRight, X, Calculator, Loader2, Zap } from "lucide-react";

function ClaimAmountPage() {
  const location = useLocation();
  const navigate = useNavigate();
  
  // view can be "approved" or "prediction"
  const [view, setView] = useState(location.state?.autoApproved ? "approved" : "initial"); 
  const [result, setResult] = useState(null);
  const [loading, setLoading] = useState(false);

  const handlePredict = async () => {
    setLoading(true);
    try {
      // Hits your Payout Estimation logic
      const res = await API.post("/predict/claim-value"); 
      setResult(res.data.estimated_amount);
      setView("prediction");
    } catch (err) {
      console.error("Valuation engine error");
    } finally {
      setLoading(false);
    }
  };

  return (
    <div className="min-h-screen bg-black text-white p-8 font-mono flex items-center justify-center">
      <div className="w-full max-w-xl border border-white p-12 relative bg-black shadow-2xl">
        
        {/* --- VIEW: AUTO-APPROVED MESSAGE --- */}
        {view === "approved" && (
          <div className="text-center space-y-10 animate-in zoom-in duration-500">
            <div className="flex justify-center">
              <div className="p-5 border-2 border-white rounded-full">
                <ShieldCheck size={50} className="text-white" />
              </div>
            </div>
            <div className="space-y-4">
              <h2 className="text-4xl font-black uppercase tracking-tighter">Your Claim Was Auto Approved</h2>
              <p className="text-[10px] text-gray-500 uppercase tracking-[0.4em]">Validation Result: SUCCESS // Risk_Score: 0.00</p>
            </div>

            <div className="space-y-4 pt-6">
              <button 
                onClick={handlePredict}
                className="w-full bg-white text-black py-5 font-black uppercase flex items-center justify-center gap-3 hover:bg-gray-200 transition-all shadow-[0_0_20px_rgba(255,255,255,0.2)]"
              >
                {loading ? <Loader2 className="animate-spin" /> : <>Predict My Claimable Amount <ArrowRight size={20} /></>}
              </button>
              
              <button 
                onClick={() => navigate("/customer/claim")} // Redirects to ClaimAmount.js
                className="w-full text-xs text-gray-500 hover:text-white uppercase tracking-widest transition-colors flex items-center justify-center gap-2"
              >
                <X size={14} /> No, Thanks
              </button>
            </div>
          </div>
        )}

        {/* --- VIEW: PREDICTION RESULT --- */}
        {view === "prediction" && (
          <div className="text-center space-y-10 animate-in slide-in-from-bottom-4 duration-500">
            <h2 className="text-xl font-bold uppercase border-b border-white pb-6 flex justify-center items-center gap-3 tracking-widest">
              <Calculator size={24}/> Valuated_Payout
            </h2>
            <div className="py-16 border-2 border-white bg-white/5 relative overflow-hidden group">
              <Zap size={100} className="absolute -right-8 -top-8 text-white/5 group-hover:text-white/10 transition-all" />
              <span className="text-[10px] text-gray-500 uppercase tracking-widest font-bold">Estimated Disbursement Limit</span>
              <h3 className="text-7xl font-black mt-3 tracking-tighter">${result?.toLocaleString()}</h3>
            </div>
            <button 
              onClick={() => navigate("/customer/dashboard")} 
              className="w-full border border-white py-5 font-bold uppercase hover:bg-white hover:text-black transition-all tracking-widest"
            >
              Return to Control Center
            </button>
          </div>
        )}

        <div className="absolute -bottom-12 left-0 right-0 text-center">
          <span className="text-[8px] text-gray-800 uppercase tracking-[1em]">Secure_Verification_Node_Active</span>
        </div>
      </div>
    </div>
  );
}

export default ClaimAmountPage;
