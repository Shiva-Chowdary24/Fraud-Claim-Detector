import React, { useState } from "react";
import API from "../services/api"; // Ensure path is correct
import { Calculator, Zap, AlertCircle, ArrowRight, Activity, ShieldCheck } from "lucide-react";
import { toast } from "react-toastify";

function ClaimAmountPage() {
  const [formData, setFormData] = useState({ age: "", incidents: "" });
  const [loading, setLoading] = useState(false);
  const [result, setResult] = useState(null);

  const handlePredict = async (e) => {
    e.preventDefault();
    setLoading(true);
    try {
      // This hits the FastAPI route we just discussed
      const res = await API.post("/predict/claim-value", formData);
      setResult(res.data.estimated_amount);
      toast.success("Calculation Complete");
    } catch (err) {
      toast.error("Prediction Engine Error");
    } finally {
      setLoading(false);
    }
  };

  return (
    <div className="min-h-screen bg-black text-white p-6 md:p-12 font-mono">
      <div className="max-w-2xl mx-auto border border-white p-8 md:p-12">
        
        {/* Header Section */}
        <div className="border-b border-white pb-6 mb-10">
          <h1 className="text-3xl font-black uppercase tracking-tighter flex items-center gap-3">
            <Calculator className="text-white" size={32} /> Payout_Valuation
          </h1>
          <p className="text-[10px] text-gray-500 mt-2 uppercase tracking-widest">
            Verification Status: <span className="text-green-500">[ADMIN_APPROVED]</span>
          </p>
        </div>

        {result !== null ? (
          /* RESULT VIEW */
          <div className="space-y-8 animate-in fade-in zoom-in duration-500">
            <div className="border-2 border-white p-10 text-center relative overflow-hidden">
              <Zap className="absolute -right-4 -top-4 text-white/10" size={100} />
              <p className="text-xs uppercase tracking-widest text-gray-400 mb-2">Estimated Payout Limit</p>
              <h2 className="text-6xl font-black">${result.toLocaleString()}</h2>
            </div>

            <div className="bg-white/5 p-4 border-l-4 border-white flex gap-4 items-start">
              <ShieldCheck className="shrink-0 mt-1" size={20} />
              <p className="text-[10px] leading-relaxed uppercase">
                This estimate is generated by the RISK_ASSESS_MODEL_V3 based on your historical data and current policy tenure. Final disbursement may vary by ±5%.
              </p>
            </div>

            <button 
              onClick={() => setResult(null)}
              className="w-full border border-white py-4 font-bold uppercase hover:bg-white hover:text-black transition-all"
            >
              ← Recalculate with New Parameters
            </button>
          </div>
        ) : (
          /* INPUT FORM VIEW */
          <form onSubmit={handlePredict} className="space-y-12">
            <div className="flex gap-4 p-4 border border-dashed border-gray-800">
              <AlertCircle className="text-gray-500 shrink-0" size={20} />
              <p className="text-[10px] text-gray-500 uppercase leading-tight">
                Please enter the specific variables requested by the auditor. These values will be processed through the claim-valuation algorithm.
              </p>
            </div>

            <div className="space-y-10">
              {/* Age Input */}
              <div className="relative group">
                <div className="flex items-center gap-4 mb-2">
                  <Activity size={18} className="text-gray-500 group-focus-within:text-white" />
                  <label className="text-xs uppercase font-bold tracking-widest">Policyholder Age</label>
                </div>
                <input 
                  type="number" 
                  placeholder="E.G. 45"
                  required
                  className="w-full bg-transparent border-b border-gray-800 py-3 px-2 outline-none focus:border-white transition-all text-xl font-bold"
                  onChange={(e) => setFormData({...formData, age: e.target.value})}
                />
              </div>

              {/* Incidents Input */}
              <div className="relative group">
                <div className="flex items-center gap-4 mb-2">
                  <ShieldAlert size={18} className="text-gray-500 group-focus-within:text-white" />
                  <label className="text-xs uppercase font-bold tracking-widest">Incident History (Count)</label>
                </div>
                <input 
                  type="number" 
                  placeholder="E.G. 0"
                  required
                  className="w-full bg-transparent border-b border-gray-800 py-3 px-2 outline-none focus:border-white transition-all text-xl font-bold"
                  onChange={(e) => setFormData({...formData, incidents: e.target.value})}
                />
              </div>
            </div>

            <button 
              disabled={loading}
              className="w-full border border-white py-5 text-lg font-black uppercase flex items-center justify-center gap-4 hover:bg-white hover:text-black transition-all group"
            >
              {loading ? (
                <div className="w-6 h-6 border-2 border-white/30 border-t-white rounded-full animate-spin" />
              ) : (
                <>Generate AI Prediction <ArrowRight size={20} className="group-hover:translate-x-2 transition-transform" /></>
              )}
            </button>
          </form>
        )}

        <div className="mt-12 text-center">
          <p className="text-[8px] text-gray-700 tracking-[0.3em] uppercase">
            System_Security_Hash: 882x-PF92-K0L1
          </p>
        </div>
      </div>
    </div>
  );
}

export default ClaimAmountPage;
