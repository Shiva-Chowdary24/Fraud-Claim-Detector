import React, { useState } from "react";
import { useLocation, useNavigate } from "react-router-dom";
import API from "../services/api";
import { ShieldCheck, ArrowRight, X, Calculator, Loader2 } from "lucide-react";

function ClaimAmountPage() {
  const location = useLocation();
  const navigate = useNavigate();

  // ✅ HANDSHAKE: Catch the 'autoApproved' flag from location.state
  const [view, setView] = useState(location.state?.autoApproved ? "approved" : "initial");
  const [result, setResult] = useState(null);
  const [loading, setLoading] = useState(false);

  const handlePredict = async () => {
    setLoading(true);
    try {
      const res = await API.post("/predict/claim-value");
      setResult(res.data.estimated_amount);
      setView("prediction");
    } catch (err) {
      console.error("Prediction Engine Error");
    } finally {
      setLoading(false);
    }
  };

  return (
    <div className="min-h-screen bg-black text-white p-8 font-mono flex items-center justify-center">
      <div className="w-full max-w-xl border border-white p-12 relative bg-black">
        
        {/* --- AUTO-APPROVED SCREEN --- */}
        {view === "approved" && (
          <div className="text-center space-y-10 animate-in zoom-in">
            <ShieldCheck size={64} className="mx-auto" />
            <h2 className="text-3xl font-black uppercase">Your Claim Was Auto Approved</h2>
            <div className="space-y-4 pt-6">
              <button 
                onClick={handlePredict} 
                className="w-full bg-white text-black py-5 font-black uppercase hover:bg-gray-200 flex justify-center items-center gap-3"
              >
                {loading ? <Loader2 className="animate-spin" /> : <>Predict My Claimable Amount <ArrowRight size={20} /></>}
              </button>
              
              {/* ✅ REDIRECT: Back to the form page */}
              <button 
                onClick={() => navigate("/customer/claim")} 
                className="w-full text-xs text-gray-500 hover:text-white uppercase flex items-center justify-center gap-1"
              >
                <X size={12} /> No, Thanks
              </button>
            </div>
          </div>
        )}

        {/* --- PREDICTION RESULT --- */}
        {view === "prediction" && (
          <div className="text-center space-y-10 animate-in slide-in-from-bottom-4">
            <h2 className="text-xl font-bold uppercase border-b border-white pb-6 tracking-widest flex justify-center items-center gap-2">
              <Calculator size={20}/> Valuated_Payout
            </h2>
            <div className="py-16 border-2 border-white bg-white/5">
              <span className="text-[10px] text-gray-500 uppercase tracking-widest">Estimated Disbursement</span>
              <h3 className="text-7xl font-black mt-2 tracking-tighter">${result?.toLocaleString()}</h3>
            </div>
            <button 
              onClick={() => navigate("/customer/dashboard")} 
              className="w-full border border-white py-5 font-bold uppercase hover:bg-white hover:text-black transition-all"
            >
              Return to Dashboard
            </button>
          </div>
        )}
      </div>
    </div>
  );
}

export default ClaimAmountPage;
