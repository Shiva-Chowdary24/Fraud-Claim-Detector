import React, { useState } from "react";
import API from "../api";
import { ShieldCheck, ArrowRight, X, Calculator, Search, AlertCircle } from "lucide-react";

function ClaimAmountPage() {
  // States to manage the flow: 'initial' -> 'approved' -> 'prediction'
  const [view, setView] = useState("initial"); 
  const [formData, setFormData] = useState({ age: "", incidents: "" });
  const [result, setResult] = useState(null);
  const [loading, setLoading] = useState(false);

  // 1. Initial Check (The "Auto-Approval" Logic)
  const handleVerify = (e) => {
    e.preventDefault();
    setLoading(true);
    
    // Simulate a fraud check delay
    setTimeout(() => {
      setLoading(false);
      setView("approved"); // Move to the "Auto Approved" message
    }, 1500);
  };

  // 2. Prediction Logic
  const handlePredict = async () => {
    setLoading(true);
    try {
      const res = await API.post("/predict/claim-value", formData);
      setResult(res.data.estimated_amount);
      setView("prediction");
    } catch (err) {
      console.error("Prediction failed");
    } finally {
      setLoading(false);
    }
  };

  return (
    <div className="min-h-screen bg-black text-white p-8 font-mono flex items-center justify-center">
      <div className="w-full max-w-xl border border-white p-10 relative">
        
        {/* --- VIEW 1: INITIAL DATA ENTRY --- */}
        {view === "initial" && (
          <div className="space-y-8 animate-in fade-in duration-500">
            <h2 className="text-xl font-bold uppercase tracking-widest border-b border-white pb-4 flex items-center gap-3">
              <Search size={20} /> Identity_Verification
            </h2>
            <form onSubmit={handleVerify} className="space-y-6">
              <input 
                type="number" 
                placeholder="ENTER_AGE" 
                className="w-full bg-transparent border-b border-gray-800 p-2 outline-none focus:border-white transition-all"
                onChange={(e) => setFormData({...formData, age: e.target.value})}
                required
              />
              <input 
                type="number" 
                placeholder="INCIDENT_COUNT" 
                className="w-full bg-transparent border-b border-gray-800 p-2 outline-none focus:border-white transition-all"
                onChange={(e) => setFormData({...formData, incidents: e.target.value})}
                required
              />
              <button className="w-full border border-white py-3 font-bold uppercase hover:bg-white hover:text-black transition-all">
                {loading ? "SCANNING..." : "Verify Claim Status"}
              </button>
            </form>
          </div>
        )}

        {/* --- VIEW 2: AUTO-APPROVED MESSAGE (Your Requested Step) --- */}
        {view === "approved" && (
          <div className="text-center space-y-8 animate-in zoom-in duration-300">
            <div className="flex justify-center text-green-500">
              <ShieldCheck size={64} />
            </div>
            <div className="space-y-2">
              <h2 className="text-2xl font-black uppercase tracking-tighter">Your Claim Was Auto Approved</h2>
              <p className="text-[10px] text-gray-500 uppercase tracking-widest">No fraudulent activity detected in current session.</p>
            </div>

            <div className="space-y-4">
              <button 
                onClick={handlePredict}
                className="w-full bg-white text-black py-4 font-black uppercase flex items-center justify-center gap-2 hover:bg-gray-200 transition-all"
              >
                Predict My Claimable Amount <ArrowRight size={18} />
              </button>
              
              <button 
                onClick={() => setView("initial")} // Redirects back to the same page
                className="w-full text-xs text-gray-500 hover:text-white uppercase tracking-widest transition-colors flex items-center justify-center gap-1"
              >
                <X size={12} /> No, Thanks
              </button>
            </div>
          </div>
        )}

        {/* --- VIEW 3: PREDICTION RESULT --- */}
        {view === "prediction" && (
          <div className="text-center space-y-8 animate-in slide-in-from-bottom-4 duration-500">
            <h2 className="text-xl font-bold uppercase border-b border-white pb-4"><Calculator className="inline mr-2"/> Valuated_Payout</h2>
            <div className="py-10 border-2 border-dashed border-white">
              <span className="text-[10px] text-gray-500 uppercase">Estimated Total</span>
              <h3 className="text-6xl font-black mt-2">${result?.toLocaleString()}</h3>
            </div>
            <button 
              onClick={() => setView("initial")} 
              className="w-full border border-white py-3 font-bold uppercase hover:bg-white hover:text-black transition-all"
            >
              Restart Process
            </button>
          </div>
        )}

        {/* Bottom System Tag */}
        <div className="absolute -bottom-6 left-0 right-0 text-center">
          <span className="text-[8px] text-gray-800 uppercase tracking-[0.5em]">Auth_Session_Active // {new Date().getFullYear()}</span>
        </div>
      </div>
    </div>
  );
}

export default ClaimAmountPage;
