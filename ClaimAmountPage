import React, { useState } from "react";
import { useLocation, useNavigate } from "react-router-dom";
import API from "../services/api";
import { ShieldCheck, ArrowRight, X, Calculator, Loader2, Sparkles } from "lucide-react";

function ClaimAmountPage() {
  const location = useLocation();
  const navigate = useNavigate();
  
  // Handshake from ClaimAmount.js
  const [view, setView] = useState(location.state?.autoApproved ? "approved" : "initial"); 
  const [result, setResult] = useState(null);
  const [loading, setLoading] = useState(false);

  const handlePredict = async () => {
    setLoading(true);
    try {
      const res = await API.post("/predict/claim-value"); 
      setResult(res.data.estimated_amount);
      setView("prediction");
    } catch (err) {
      console.error("Valuation failed");
    } finally {
      setLoading(false);
    }
  };

  return (
    <div className="min-h-screen bg-[#0f172a] text-slate-200 p-6 font-sans flex items-center justify-center">
      {/* Medium Sized Container (max-w-md) */}
      <div className="w-full max-w-md bg-[#1e293b] border border-slate-700 rounded-3xl shadow-2xl p-8 relative overflow-hidden">
        
        {/* Decorative background glow */}
        <div className="absolute -top-24 -left-24 w-48 h-48 bg-blue-500/10 blur-3xl rounded-full"></div>

        {/* --- VIEW: AUTO-APPROVED --- */}
        {view === "approved" && (
          <div className="text-center space-y-6 animate-in fade-in zoom-in duration-500">
            <div className="flex justify-center">
              <div className="bg-emerald-500/10 p-4 rounded-2xl border border-emerald-500/20">
                <ShieldCheck size={48} className="text-emerald-400" />
              </div>
            </div>
            
            <div className="space-y-2">
              <h2 className="text-2xl font-bold text-white tracking-tight">Claim Auto-Approved</h2>
              <p className="text-sm text-slate-400 px-4">
                Our AI engine found no irregularities. You are eligible for an immediate payout estimation.
              </p>
            </div>

            <div className="space-y-3 pt-4">
              <button 
                onClick={handlePredict} 
                className="w-full bg-blue-600 hover:bg-blue-500 text-white py-4 rounded-xl font-bold flex justify-center items-center gap-2 transition-all active:scale-95 shadow-lg shadow-blue-900/20"
              >
                {loading ? <Loader2 className="animate-spin" /> : (
                  <>
                    <Sparkles size={18} />
                    Predict Payout Amount
                  </>
                )}
              </button>

              <button 
                onClick={() => navigate("/customer/predict")} 
                className="w-full text-sm text-slate-500 hover:text-slate-300 font-medium py-2 transition-colors flex items-center justify-center gap-1"
              >
                No, thanks. I'll do it later.
              </button>
            </div>
          </div>
        )}

        {/* --- VIEW: PREDICTION RESULT --- */}
        {view === "prediction" && (
          <div className="text-center space-y-6 animate-in slide-in-from-bottom-8 duration-500">
            <div className="inline-flex items-center gap-2 bg-slate-800 px-4 py-1.5 rounded-full border border-slate-700 mb-2">
              <Calculator size={14} className="text-blue-400" />
              <span className="text-xs font-bold uppercase tracking-wider text-slate-300">Valuation Result</span>
            </div>

            <div className="bg-gradient-to-b from-slate-800 to-slate-900 border border-slate-700 rounded-2xl py-10 shadow-inner">
              <p className="text-xs text-slate-500 uppercase font-bold tracking-widest">Estimated Disbursement</p>
              <h3 className="text-5xl font-black text-white mt-3 tracking-tighter">
                <span className="text-blue-500">$</span>{result?.toLocaleString()}
              </h3>
            </div>

            <div className="pt-4 space-y-3">
              <button 
                onClick={() => navigate("/customer/dashboard")} 
                className="w-full bg-slate-100 hover:bg-white text-slate-900 py-4 rounded-xl font-bold transition-all active:scale-95"
              >
                Return to Dashboard
              </button>
              <p className="text-[10px] text-slate-500">
                This is a model-generated estimate. Final amount subject to adjustment.
              </p>
            </div>
          </div>
        )}

      </div>
    </div>
  );
}

export default ClaimAmountPage;
